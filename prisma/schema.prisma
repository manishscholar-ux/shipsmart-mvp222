// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  businessName  String?
  businessType  String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  zipCode       String?
  country       String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  orders        Order[]
  carrierAccounts CarrierAccount[]
  subscriptions Subscription[]
  invoices      Invoice[]
  apiKeys       ApiKey[]
  sessions      Session[]
  
  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  sessionToken String @unique
  userId    String
  expires   DateTime
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  userId          String
  status          OrderStatus @default(PENDING)
  
  // Shipment info
  fromName        String
  fromEmail       String?
  fromPhone       String?
  fromAddressLine1 String
  fromAddressLine2 String?
  fromCity        String
  fromState       String
  fromZip         String
  fromCountry     String @default("US")
  
  toName          String
  toEmail         String?
  toPhone         String?
  toAddressLine1  String
  toAddressLine2  String?
  toCity          String
  toState         String
  toZip           String
  toCountry       String @default("US")
  
  // Package info
  weight          Float
  weightUnit      String @default("lbs")
  length          Float?
  width           Float?
  height          Float?
  dimensionUnit   String @default("in")
  description     String?
  
  // Shipping
  selectedCarrier String?
  selectedService String?
  selectedRate    Float?
  labelId         String?
  trackingNumber  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  label Label?
  
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model Label {
  id              String    @id @default(cuid())
  orderId         String    @unique
  carrier         String
  trackingNumber  String
  labelData       Bytes     // PDF binary data
  labelFormat     String @default("PDF")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([trackingNumber])
}

model CarrierAccount {
  id          String    @id @default(cuid())
  userId      String
  carrier     String    // UPS, FedEx, USPS, DHL
  accountNumber String
  isActive    Boolean   @default(true)
  apiKey      String?
  apiSecret   String?
  credentials Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, carrier])
  @@index([userId])
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String    @unique
  stripeCustomerId String @unique
  tier        SubscriptionTier @default(STARTER)
  status      SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Invoice {
  id          String    @id @default(cuid())
  userId      String
  stripeInvoiceId String @unique
  amount      Float
  currency    String @default("USD")
  status      InvoiceStatus @default(DRAFT)
  invoiceDate DateTime
  dueDate     DateTime?
  paidDate    DateTime?
  pdfUrl      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  key         String    @unique
  name        String?
  revoked     Boolean   @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// Enums
enum OrderStatus {
  PENDING
  LABELED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}
