# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shipsmart"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Carrier APIs
USPS_API_USERNAME="your_usps_api_username"
USPS_API_PASSWORD="your_usps_api_password"
UPS_API_KEY="your_ups_api_key"
UPS_API_SECRET="your_ups_api_secret"
FEDEX_API_KEY="your_fedex_api_key"
FEDEX_API_SECRET="your_fedex_api_secret"
DHL_API_KEY="your_dhl_api_key"
DHL_API_SECRET="your_dhl_api_secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_secret"

# Email Service (Resend)
RESEND_API_KEY="re_your_api_key"

# AWS S3 (for label storage)
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="shipsmart-labels"

# General
NODE_ENV="development"
